rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════════

    // Semak user log masuk
    function isAuth() {
      return request.auth != null;
    }

    // Baca data user dari Firestore (cached oleh Firebase dalam 1 request)
    function myData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Semak role
    function isSuperadmin() {
      return isAuth() && myData().get('role', '') == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && myData().get('role', '') == 'admin';
    }

    function isTeacher() {
      return isAuth() && myData().get('role', '') == 'teacher';
    }

    // Semak admin/teacher milik sekolah ini
    function isMySchool(schoolId) {
      return isAuth() && myData().get('schoolId', '') == schoolId;
    }

    // Admin atau superadmin untuk sekolah ini
    function canAccessSchool(schoolId) {
      return isSuperadmin() || (isAdmin() && isMySchool(schoolId));
    }

    // Teacher boleh tulis heat (input keputusan) untuk sekolah sendiri
    function canWriteHeat(schoolId) {
      return isSuperadmin()
        || (isAdmin() && isMySchool(schoolId))
        || (isTeacher() && isMySchool(schoolId));
    }

    // Admin/teacher/superadmin untuk sekolah ini (baca sahaja)
    function canReadSchool(schoolId) {
      return isSuperadmin()
        || ((isAdmin() || isTeacher()) && isMySchool(schoolId));
    }

    // ══════════════════════════════════════════════════════════════════════════
    // LOGIN ATTEMPTS — rate limiting (buka penuh, tiada data sensitif)
    // ══════════════════════════════════════════════════════════════════════════

    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // USERS — profil pengguna
    // ══════════════════════════════════════════════════════════════════════════

    match /users/{uid} {
      // User baca profil sendiri; superadmin baca semua; admin baca user dalam schoolId sendiri
      allow read: if isAuth() && (
        request.auth.uid == uid
        || isSuperadmin()
        || (isAdmin() && myData().get('schoolId','') != '')
      );

      // Superadmin boleh tulis mana-mana; admin hanya tulis user dalam schoolId sendiri
      allow write: if isSuperadmin()
        || (isAdmin() && isMySchool(resource.data.get('schoolId','')));

      // First-run: user baharu cipta profil sendiri (superadmin pertama sahaja)
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && request.resource.data.get('role', '') == 'superadmin';

      // Senarai user: superadmin atau admin (admin urus teacher sekolah sendiri)
      allow list: if isSuperadmin() || isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // TENANTS — data sekolah (multi-tenant root)
    // ══════════════════════════════════════════════════════════════════════════

    // Profil sekolah — read awam (namaSekolah, daerah, slug, status untuk landing page)
    // Data sensitif (emelAdmin, adminUid) ada dalam doc tapi landing page tidak paparkan
    match /tenants/{schoolId} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ── Data sensitif admin — private, superadmin sahaja ─────────────────────
    match /tenants/{schoolId}/_private/{docId} {
      allow read, write: if isSuperadmin();
    }

    // ── Tetapan awam — home, galeri, bukuKejohananLink, bukuProgram, atletTerbaik
    // (dibaca oleh Home public page dan landing page)
    match /tenants/{schoolId}/tetapan/{docId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    // ── Atlet master — private (mengandungi noKP, PDPA sensitif) ─────────────
    match /tenants/{schoolId}/atlet/{atletId} {
      allow read:   if canReadSchool(schoolId);
      allow write:  if canAccessSchool(schoolId);
    }

    // ── Kejohanan ─────────────────────────────────────────────────────────────
    // Baca asas (nama, tarikh, status, lokasi) dibenar awam — untuk landing page sekolah
    match /tenants/{schoolId}/kejohanan/{kejId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    // ── Heat — flat di bawah kejohanan (bukan nested dalam acara) ────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/heat/{heatId} {
      allow read:  if true;   // keputusan boleh dilihat awam di Home
      allow write: if canWriteHeat(schoolId);
    }

    // ── Acara, jadual — awam (jadual & keputusan untuk Home public) ──────────
    match /tenants/{schoolId}/kejohanan/{kejId}/acara/{docId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/jadual/{docId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/jadual_khas/{docId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    // ── Medal tally — awam (untuk paparan Home) ───────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/medal_tally/{docId} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    // ── Mata olahragawan — private (ada noKP) ────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/mata_olahragawan/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // ── Semua subcollection lain dalam kejohanan ──────────────────────────────
    // (kategori, pendaftaran, pengesahan, pilihan_olahragawan, anugerah_custom, dll)
    match /tenants/{schoolId}/kejohanan/{kejId}/{subcol}/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // Wildcard untuk subcollection yang lebih dalam jika ada
    match /tenants/{schoolId}/kejohanan/{kejId}/{path=**} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // ── Rekod kejohanan — baca awam (untuk landing page), tulis admin sahaja ──
    match /tenants/{schoolId}/rekod/{rekodKey} {
      allow read:  if true;
      allow write: if canAccessSchool(schoolId);
    }

    // ── Rekod sejarah — private ───────────────────────────────────────────────
    match /tenants/{schoolId}/rekod_sejarah/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // ── Sekolah pasukan — baca oleh teacher (untuk login) ────────────────────
    match /tenants/{schoolId}/sekolah/{kodSekolah} {
      allow read:  if true;   // diperlukan untuk Lupa PIN (public)
      allow write: if canAccessSchool(schoolId);
    }

    // ── Users per-tenant (pencatat, urusetia, dll) — PDPA, admin sahaja ──────
    match /tenants/{schoolId}/users/{uid} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // ── Login attempts per-tenant — tulis tanpa auth (proses login) ──────────
    match /tenants/{schoolId}/login_attempts/{docId} {
      allow read, write: if true;
    }

    // Wildcard untuk semua lain dalam tenant (selamat, ikut sekolah)
    match /tenants/{schoolId}/{path=**} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canAccessSchool(schoolId);
    }

    // ══════════════════════════════════════════════════════════════════════════
    // SLUG INDEX — lookup awam untuk URL per sekolah (/ska, /skb, dll)
    // Tiada data sensitif: hanya namaSekolah, daerah, slug, aktif
    // ══════════════════════════════════════════════════════════════════════════

    match /slugIndex/{slug} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // DEMO — data awam untuk demo/landing
    // ══════════════════════════════════════════════════════════════════════════

    match /demo/{document=**} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // BLOCK SEMUA — default deny
    // ══════════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
