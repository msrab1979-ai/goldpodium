rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function canAccessSchool(schoolId) {
      return isAuth() && userExists() && (
        userDoc().data.role == 'superadmin'
        || (userDoc().data.role == 'admin' && userDoc().data.schoolId == schoolId)
      );
    }

    function canReadSchool(schoolId) {
      return isAuth() && userExists() && (
        userDoc().data.role == 'superadmin'
        || ((userDoc().data.role == 'admin' || userDoc().data.role == 'teacher') && userDoc().data.schoolId == schoolId)
      );
    }

    function isSuperadmin() {
      return isAuth() && userExists() && userDoc().data.role == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && userExists() && userDoc().data.role == 'admin';
    }

    // ── Login attempts ────────────────────────────────────────────────────────
    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ── Users root collection ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isSuperadmin() || isAdmin());
      allow list: if isSuperadmin() || isAdmin();
      allow write: if isSuperadmin()
        || (isAdmin() && resource != null && userDoc().data.schoolId == resource.data.schoolId);
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role == 'superadmin'
        && !userExists();
    }

    // ── Tenants root doc ──────────────────────────────────────────────────────
    match /tenants/{schoolId} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ── Private ───────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/_private/{docId} {
      allow read, write: if isSuperadmin();
    }

    // ── Tetapan ───────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/tetapan/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Atlet ─────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/atlet/{atletId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Kejohanan ─────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Heat ──────────────────────────────────────────────────────────────────
    // write: if true — pencatat guna PIN + sessionStorage, tiada Firebase Auth.
    // Concurrent write dilindungi oleh runTransaction dalam InputKeputusan.jsx.
    match /tenants/{schoolId}/kejohanan/{kejId}/heat/{heatId} {
      allow read, write: if true;
    }

    // ── Acara ─────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/acara/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Jadual ────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/jadual/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/jadual_khas/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Medal tally ───────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/medal_tally/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Mata olahragawan ──────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/mata_olahragawan/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if isAuth();
    }

    // ── Pengesahan ────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/pengesahan/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    // ── Pendaftaran ───────────────────────────────────────────────────────────
    // write: if true — pencatat/pasukan pendaftaran tiada Firebase Auth (PIN-based)
    match /tenants/{schoolId}/kejohanan/{kejId}/pendaftaran/{docId} {
      allow read:  if true;
      allow write: if true;
    }

    // ── Pendaftaran counter ───────────────────────────────────────────────────
    match /tenants/{schoolId}/pendaftaran_counter/{docId} {
      allow read, write: if true;
    }

    // ── Subcollection kejohanan lain ──────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/{subcol}/{docId} {
      allow read:  if true;
      allow write: if isAuth();
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/{path=**} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Rekod ─────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/rekod/{rekodKey} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Rekod sejarah ─────────────────────────────────────────────────────────
    match /tenants/{schoolId}/rekod_sejarah/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if isAuth();
    }

    // ── Sekolah pasukan ───────────────────────────────────────────────────────
    match /tenants/{schoolId}/sekolah/{kodSekolah} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Users per-tenant ──────────────────────────────────────────────────────
    match /tenants/{schoolId}/users/{uid} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Login attempts per-tenant ─────────────────────────────────────────────
    match /tenants/{schoolId}/login_attempts/{docId} {
      allow read, write: if true;
    }

    // ── Wildcard tenant ───────────────────────────────────────────────────────
    match /tenants/{schoolId}/{path=**} {
      allow read:  if true;
      allow write: if isAuth();
    }

    // ── Slug index ────────────────────────────────────────────────────────────
    match /slugIndex/{slug} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ── Demo ──────────────────────────────────────────────────────────────────
    match /demo/{document=**} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
