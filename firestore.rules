rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper — baca role dari Firestore (bukan custom claims) ──────────────

    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return isAuth()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }

    function isSuperadmin() {
      return isAuth() && getUserRole() == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && getUserRole() == 'admin';
    }

    function isAdminOfSchool(schoolId) {
      return isAdmin()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('schoolId', '') == schoolId;
    }

    function getUserData(schoolId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('schoolId', '') == schoolId;
    }

    // ── Login attempts — buka untuk rate limiting ─────────────────────────────

    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isSuperadmin());
      allow write: if isSuperadmin();
      // First-run: user cipta doc sendiri sebagai superadmin (0 superadmin semasa)
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'superadmin';
      // Count query untuk semak bilangan superadmin semasa setup
      allow list: if isAuth();
    }

    // ── Superadmin — akses penuh ──────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if isSuperadmin();
    }

    // ── Tenants ───────────────────────────────────────────────────────────────

    match /tenants/{schoolId} {
      allow read: if isAuth() && (isSuperadmin() || getUserData(schoolId));
      allow write: if isSuperadmin();
    }

    match /tenants/{schoolId}/kejohanan/{kejId} {
      allow read, write: if isAuth() && (isSuperadmin() || isAdminOfSchool(schoolId));
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/{sub=**} {
      allow read, write: if isAuth() && (isSuperadmin() || isAdminOfSchool(schoolId));
    }

    match /tenants/{schoolId}/{document=**} {
      allow read, write: if isSuperadmin();
    }

    // ── Demo — baca awam ──────────────────────────────────────────────────────

    match /demo/{document=**} {
      allow read: if true;
      allow write: if isSuperadmin();
    }

    // ── Block semua lain ──────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
