rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: role checks (Firebase Auth users) ────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperadmin() {
      return isAuth() && userExists() && userDoc().data.role == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && userExists() && userDoc().data.role == 'admin';
    }

    function isAdminOfSchool(schoolId) {
      return isAdmin() && userDoc().data.schoolId == schoolId;
    }

    // ─── Helper: session doc (Anonymous users — pencatat/pengurus) ────────────
    // Session doc dicipta oleh client selepas signInAnonymously + PIN verified.
    // Rules percaya session doc untuk semak schoolId — cegah cross-tenant write.
    function sessionExists(schoolId) {
      return isAuth()
        && exists(/databases/$(database)/documents/tenants/$(schoolId)/sessions/$(request.auth.uid));
    }

    // Baca data user doc dalam tenant (untuk sahkan session pencatat).
    function getUserDoc(schoolId, userDocId) {
      return get(/databases/$(database)/documents/tenants/$(schoolId)/users/$(userDocId)).data;
    }

    // Gabungan: sesiapa yang authorized tulis dalam tenant tertentu
    function canWriteTenant(schoolId) {
      return isSuperadmin()
        || isAdminOfSchool(schoolId)
        || sessionExists(schoolId);
    }

    // Superadmin + admin sekolah + guru (baca sahaja untuk laporan admin)
    function canReadSchool(schoolId) {
      return isAuth() && userExists() && (
        userDoc().data.role == 'superadmin'
        || ((userDoc().data.role == 'admin' || userDoc().data.role == 'teacher') && userDoc().data.schoolId == schoolId)
      );
    }

    // ─── Login attempts (rate limiting) ───────────────────────────────────────
    // Public write kekal — perlu untuk track sebelum auth. Rate limit di server.
    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ─── Users root collection ────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isSuperadmin() || isAdmin());
      allow list: if isSuperadmin() || isAdmin();
      allow write: if isSuperadmin()
        || (isAdmin() && resource != null && userDoc().data.schoolId == resource.data.schoolId);
      allow create: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.role == 'superadmin'
        && !userExists();
    }

    // ─── Tenants root doc ─────────────────────────────────────────────────────
    match /tenants/{schoolId} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ─── Private data ─────────────────────────────────────────────────────────
    match /tenants/{schoolId}/_private/{docId} {
      allow read, write: if isSuperadmin();
    }

    // ─── Sejarah langganan (superadmin sahaja — audit trail bayaran) ──────────
    match /tenants/{schoolId}/langganan_sejarah/{docId} {
      allow read, write: if isSuperadmin();
    }
    // Collection group query untuk agregasi merentas semua tenant (Tab Akaun)
    match /{path=**}/langganan_sejarah/{docId} {
      allow read: if isSuperadmin();
    }

    // ─── Sessions (Anonymous Auth pencatat/pengurus) ──────────────────────────
    // Client tulis session doc selepas signInAnonymously + PIN verified.
    // Constraints:
    //   1. Hanya UID sendiri boleh cipta session dokumennya
    //   2. schoolId dalam path mesti match schoolId dalam data
    //   3. Role mesti 'pencatat' atau 'pengurus'
    //   4. Untuk 'pengurus': kodSekolah mesti wujud dalam tenants/{schoolId}/sekolah/
    //   5. Untuk 'pencatat': userDocId mesti wujud dalam tenants/{schoolId}/users/,
    //      role user doc == 'pencatat', kodAkses padan, dan user aktif.
    //   Tiada update — hanya create + delete oleh diri sendiri
    match /tenants/{schoolId}/sessions/{anonUid} {
      allow read:   if isAuth() && request.auth.uid == anonUid;
      allow delete: if isAuth() && request.auth.uid == anonUid;
      allow create: if isAuth()
        && request.auth.uid == anonUid
        && request.resource.data.schoolId == schoolId
        && (request.resource.data.role == 'pencatat' || request.resource.data.role == 'pengurus')
        && (
          // Pengurus: kena ada sekolah doc dengan kodSekolah yang sama
          (request.resource.data.role == 'pengurus'
            && exists(/databases/$(database)/documents/tenants/$(schoolId)/sekolah/$(request.resource.data.kodSekolah)))
          ||
          // Pencatat: sahkan userDocId wujud dalam users collection tenant ini,
          // role user doc == 'pencatat', kodAkses padan, dan user tidak dinyahaktifkan.
          // Ini halang session palsu — rules tidak lagi buta percaya client.
          (request.resource.data.role == 'pencatat'
            && request.resource.data.userDocId is string
            && exists(/databases/$(database)/documents/tenants/$(schoolId)/users/$(request.resource.data.userDocId))
            && getUserDoc(schoolId, request.resource.data.userDocId).role == 'pencatat'
            && getUserDoc(schoolId, request.resource.data.userDocId).kodAkses == request.resource.data.kodAkses
            && getUserDoc(schoolId, request.resource.data.userDocId).isAktif != false)
        );
      allow update: if false;
    }

    // ─── Tetapan ──────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/tetapan/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Atlet ────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/atlet/{atletId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Kejohanan ────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Heat ─────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/heat/{heatId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Acara ────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/acara/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Jadual ───────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/jadual/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    match /tenants/{schoolId}/kejohanan/{kejId}/jadual_khas/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Medal tally ──────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/medal_tally/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Mata olahragawan ─────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/mata_olahragawan/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Pengesahan ───────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/pengesahan/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Pendaftaran ──────────────────────────────────────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/pendaftaran/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Pendaftaran counter ──────────────────────────────────────────────────
    match /tenants/{schoolId}/pendaftaran_counter/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Subcollection kejohanan lain (kategori, dll) ─────────────────────────
    match /tenants/{schoolId}/kejohanan/{kejId}/{subcol}/{docId} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // Catch-all deeper paths (contoh: kejohanan/x/tetapan/finalSetup, dll)
    match /tenants/{schoolId}/kejohanan/{kejId}/{path=**} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Rekod ────────────────────────────────────────────────────────────────
    match /tenants/{schoolId}/rekod/{rekodKey} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Rekod sejarah ────────────────────────────────────────────────────────
    match /tenants/{schoolId}/rekod_sejarah/{docId} {
      allow read:  if canReadSchool(schoolId);
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Sekolah pasukan ──────────────────────────────────────────────────────
    match /tenants/{schoolId}/sekolah/{kodSekolah} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Users per-tenant (pencatat records) ──────────────────────────────────
    match /tenants/{schoolId}/users/{uid} {
      allow read:  if true;
      allow write: if canWriteTenant(schoolId);
    }

    // ─── Login attempts per-tenant ────────────────────────────────────────────
    match /tenants/{schoolId}/login_attempts/{docId} {
      allow read, write: if true;
    }

    // NOTE: catch-all `tenants/{schoolId}/{path=**}` DIBUANG kerana ia OR
    // dengan match spesifik untuk sessions/ — melemahkan constraint session doc.
    // Semua collection tenant mesti ada match spesifik di atas.
    // Untuk collection baru, tambah rule spesifik dan JANGAN guna catch-all.

    // ─── Slug index ───────────────────────────────────────────────────────────
    match /slugIndex/{slug} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ─── Demo ─────────────────────────────────────────────────────────────────
    match /demo/{document=**} {
      allow read:  if true;
      allow write: if isSuperadmin();
    }

    // ─── Security logs ────────────────────────────────────────────────────────
    match /security/{docId} {
      allow read:  if isSuperadmin();
      allow write: if isAuth();
    }

    // ─── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
