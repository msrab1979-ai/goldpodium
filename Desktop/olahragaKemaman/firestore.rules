rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuth() && getRole() == 'superadmin';
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function isPencatat() {
      return isAuth() && getRole() == 'pencatat';
    }

    function isPengurusTeknik() {
      return isAuth() && getRole() == 'pengurus_teknik';
    }

    function isAdminOrAbove() {
      return isAuth() && getRole() in ['superadmin', 'admin'];
    }

    function isStaff() {
      return isAuth() && getRole() in ['superadmin', 'admin', 'pencatat', 'pengurus_teknik'];
    }

    // ── users ─────────────────────────────────────────────────────
    // Sistem KOAM guna sessionStorage auth (bukan Firebase Auth) —
    // login perlu query users tanpa Firebase Auth token.
    // WRITE: hanya superadmin (Firebase Auth) boleh ubah.
    match /users/{uid} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── sekolah ───────────────────────────────────────────────────
    // Pengurus pasukan login guna kodSekolah+PIN — perlu baca tanpa auth.
    match /sekolah/{kodSekolah} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── login_attempts ────────────────────────────────────────────
    // Rate limiting semasa login — perlu baca/tulis tanpa Firebase Auth.
    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ── atlet ─────────────────────────────────────────────────────
    // Dashboard, pendaftaran, sijil — semua baca atlet tanpa Firebase Auth
    match /atlet/{noKP} {
      allow read: if true;
      allow create: if isAdminOrAbove();
      allow update: if isSuperAdmin() ||
        (isAdmin() && resource.data.kodSekolah ==
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.kodSekolah);
      allow delete: if isSuperAdmin();
    }

    // ── kejohanan ─────────────────────────────────────────────────
    match /kejohanan/{kejohananId} {
      allow read: if true;
      allow write: if isSuperAdmin();

      // acara (sub-collection)
      match /acara/{aceraId} {
        allow read: if true;
        allow write: if isSuperAdmin();

        // heat (sub-collection)
        // Pencatat guna sessionStorage (bukan Firebase Auth) — allow write terus
        match /heat/{heatId} {
          allow read: if true;
          allow write: if true;

          // keputusan (sub-collection)
          match /keputusan/{keputusanId} {
            allow read: if true;
            allow create, update: if true;
            allow delete: if isSuperAdmin();
          }
        }
      }

      // pendaftaran (sub-collection)
      match /pendaftaran/{noBib} {
        allow read: if true;
        allow create: if isAdminOrAbove();
        allow update: if isSuperAdmin() ||
          (isAdmin() && resource.data.kodSekolah ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.kodSekolah);
        allow delete: if isSuperAdmin();
      }

      // relay_pasukan (sub-collection)
      match /relay_pasukan/{relayId} {
        allow read: if true;
        allow create: if isAdminOrAbove();
        allow update: if isSuperAdmin() ||
          (isAdmin() && resource.data.kodSekolah ==
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.kodSekolah);
        allow delete: if isSuperAdmin();
      }
    }

    // ── rekod ─────────────────────────────────────────────────────
    match /rekod/{rekodId} {
      allow read: if true;
      allow write: if true;
    }

    // ── rekod_sejarah ─────────────────────────────────────────────
    match /rekod_sejarah/{sejarahId} {
      allow read: if true;
      allow write: if true;
    }

    // ── bantahan ─────────────────────────────────────────────────
    match /bantahan/{bantahanId} {
      allow read: if isStaff();
      allow create: if isAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── mata_olahragawan ─────────────────────────────────────────
    match /mata_olahragawan/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── jadual_acara ─────────────────────────────────────────────
    match /jadual_acara/{jadualId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── jadual_khas ───────────────────────────────────────────────
    match /jadual_khas/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── medal_tally ───────────────────────────────────────────────
    match /medal_tally/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── kategori ──────────────────────────────────────────────────
    match /kategori/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── tetapan ───────────────────────────────────────────────────
    match /tetapan/{id} {
      allow read: if true;
      allow write: if isAdminOrAbove();
    }

    // ── pilihan_olahragawan ───────────────────────────────────────
    match /pilihan_olahragawan/{id} {
      allow read: if true;
      allow write: if isAdminOrAbove();
    }

    // ── notifikasi ───────────────────────────────────────────────
    match /notifikasi/{notifId} {
      allow read: if isAuth() &&
        resource.data.penerimUid == request.auth.uid;
      allow create: if false;
      allow update: if isAuth() &&
        resource.data.penerimUid == request.auth.uid;
      allow delete: if false;
    }

    // ── audit_log ────────────────────────────────────────────────
    match /audit_log/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

  }
}
