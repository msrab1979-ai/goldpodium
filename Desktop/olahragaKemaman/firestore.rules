rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuth() && getRole() == 'superadmin';
    }

    // ── users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow write: if true;
    }

    // ── sekolah ───────────────────────────────────────────────────
    match /sekolah/{kodSekolah} {
      allow read: if true;
      allow write: if true;
    }

    // ── login_attempts ────────────────────────────────────────────
    match /login_attempts/{docId} {
      allow read, write: if true;
    }

    // ── atlet ─────────────────────────────────────────────────────
    match /atlet/{noKP} {
      allow read: if true;
      allow write: if true;
    }

    // ── kejohanan ─────────────────────────────────────────────────
    match /kejohanan/{kejohananId} {
      allow read: if true;
      allow write: if true;

      // acara (sub-collection)
      match /acara/{aceraId} {
        allow read: if true;
        allow write: if true;

        // heat (sub-collection)
        match /heat/{heatId} {
          allow read: if true;
          allow write: if true;

          // keputusan (sub-collection)
          match /keputusan/{keputusanId} {
            allow read: if true;
            allow write: if true;
          }
        }
      }

      // pendaftaran (sub-collection)
      match /pendaftaran/{noBib} {
        allow read: if true;
        allow write: if true;
      }

      // relay_pasukan (sub-collection)
      match /relay_pasukan/{relayId} {
        allow read: if true;
        allow write: if true;
      }

      // pengesahan (sub-collection)
      match /pengesahan/{pengesahanId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // ── rekod ─────────────────────────────────────────────────────
    match /rekod/{rekodId} {
      allow read: if true;
      allow write: if true;
    }

    // ── rekod_sejarah ─────────────────────────────────────────────
    match /rekod_sejarah/{sejarahId} {
      allow read: if true;
      allow write: if true;
    }

    // ── bantahan ─────────────────────────────────────────────────
    match /bantahan/{bantahanId} {
      allow read: if true;
      allow write: if true;
    }

    // ── mata_olahragawan ─────────────────────────────────────────
    match /mata_olahragawan/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── jadual_acara ─────────────────────────────────────────────
    match /jadual_acara/{jadualId} {
      allow read: if true;
      allow write: if true;
    }

    // ── jadual_khas ───────────────────────────────────────────────
    match /jadual_khas/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── medal_tally ───────────────────────────────────────────────
    match /medal_tally/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── kategori ──────────────────────────────────────────────────
    match /kategori/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── tetapan ───────────────────────────────────────────────────
    match /tetapan/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── pilihan_olahragawan ───────────────────────────────────────
    match /pilihan_olahragawan/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── notifikasi ───────────────────────────────────────────────
    match /notifikasi/{notifId} {
      allow read: if true;
      allow write: if true;
    }

    // ── medal_tally_kat ───────────────────────────────────────────
    match /medal_tally_kat/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── rekod_tuntutan ────────────────────────────────────────────
    match /rekod_tuntutan/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── wa_config ─────────────────────────────────────────────────
    match /wa_config/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── anugerah_custom ───────────────────────────────────────────
    match /anugerah_custom/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── buku_kongsi ───────────────────────────────────────────────
    match /buku_kongsi/{id} {
      allow read: if true;
      allow write: if true;
    }

    // ── audit_log ────────────────────────────────────────────────
    match /audit_log/{logId} {
      allow read: if true;
      allow write: if true;
    }

  }
}
